{
    "app-id" : "net.sapples.LiveCaptions",
    "runtime" : "org.gnome.Platform",
    "runtime-version" : "50",
    "sdk" : "org.gnome.Sdk",
    "command" : "livecaptions",
    "finish-args" : [
        "--share=ipc",
        "--device=dri",
        "--socket=wayland",
        "--socket=pulseaudio",
        "--socket=fallback-x11"
    ],
    "cleanup" : [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "/onnx_root",
        "*.la",
        "*.a"
    ],
    "build-options" : {
        "env" : {
            "ONNX_ROOT" : "/app/onnx_root"
        }
    },
    "modules" : [
        {
            "name" : "onnxruntime",
            "buildsystem" : "simple",
            "sources" : [
                {
                    "type" : "archive",
                    "only-arches" : ["x86_64"],
                    "dest" : "onnxruntime-1",
                    "url" : "https://github.com/microsoft/onnxruntime/releases/download/v1.24.4/onnxruntime-linux-x64-1.24.4.tgz",
                    "sha256" : "3a211fbea252c1e66290658f1b735b772056149f28321e71c308942cdb54b747"
                },

                {
                    "type" : "archive",
                    "only-arches" : ["aarch64"],
                    "dest" : "onnxruntime-1",
                    "url" : "https://github.com/microsoft/onnxruntime/releases/download/v1.24.4/onnxruntime-linux-aarch64-1.24.4.tgz",
                    "sha256" : "866109a9248d057671a039b9d725be4bd86888e3754140e6701ec621be9d4d7e"
                }
            ],
            "build-commands" : [
                "mkdir -p $ONNX_ROOT",
                "mv onnxruntime-1/* $ONNX_ROOT",

                "mkdir -p $FLATPAK_DEST/lib",
                "cp $ONNX_ROOT/lib/* $FLATPAK_DEST/lib"
            ]
        },

        {
            "name": "aprilmodel",
            "buildsystem" : "simple",
            "sources" : [
                {
                    "type" : "file",
                    "dest-filename" : "aprilv0_en-us.april",
                    "url" : "https://april.sapples.net/april-english-dev-01110_en.april",
                    "sha256" : "77eb95d0fa4f7708a37e868c2265301ee6c42dcb25e63ca63eea3d9cbadbc1f3"
                }
            ],
            "build-commands" : [
                "install -Dm644 aprilv0_en-us.april -t ${FLATPAK_DEST}/LiveCaptions/models"
            ]
        },

        {
            "name" : "livecaptions",
            "builddir" : true,
            "buildsystem" : "meson",
            "sources" : [
                {
                    "type" : "git",
                    "url" : "https://github.com/abb128/LiveCaptions",
                    "tag": "v0.4.2",
                    "commit" : "c3988a84ee90435246bc090c5990bd6b06ad9c27"
                }
            ]
        }
    ]
}
